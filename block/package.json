{
  "name": "@designsetgo/block",
  "version": "0.1.0",
  "private": true,
  "description": "DesignSetGo Apps Gutenberg block — embed an installed app inline in a post.",
  "scripts": {
    "build": "wp-scripts build --webpack-src-dir=src --output-path=build",
    "start": "wp-scripts start --webpack-src-dir=src --output-path=build",
    "test": "jest --passWithNoTests",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "@types/wordpress__block-editor": "^11.5.0",
    "@types/wordpress__blocks": "^12.5.0",
    "@types/wordpress__components": "^23.0.0",
    "@types/wordpress__data": "^7.0.0",
    "@wordpress/api-fetch": "^7.45.0",
    "@wordpress/block-editor": "^15.18.0",
    "@wordpress/element": "^6.45.0",
    "@wordpress/scripts": "^32.1.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1",
    "minimatch": "^9.0.7",
    "serialize-javascript": "^7.0.5",
    "webpack-dev-server": "^5.2.3"
  }
}
